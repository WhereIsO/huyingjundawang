{
    "version": 3,
    "configurePresets": [
        {
            "name": "ninja-msvc-release",
            "displayName": "Ninja + MSVC Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "$env{QT_PREFIX}",
                "CMAKE_CXX_COMPILER": "cl",
                "BACKUP_ALLOW_GTEST_DOWNLOAD": "ON"
            }
        }
    ]
}
